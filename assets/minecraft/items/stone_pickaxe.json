{ "model"
: { "type": "inexactcit:match"
  , "property": "minecraft:component"
  , "component": "minecraft:custom_name"
  , "cases"
  : [ { "regex": ".*Tir.*othelu Meracahe.*onn.*"
      , "model"
      : { "type": "minecraft:model"
        , "model"
        : "pixelatedvolume-lotc-custom-items:item/boomsteel_spike_snake"
        }
      }
    ]
  , "fallback"
  : { "type": "minecraft:model", "model": "minecraft:item/stone_pickaxe" }
  }
, "oversized_in_gui": true
}