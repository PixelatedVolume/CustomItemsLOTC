{ "model"
: { "type": "inexactcit:match"
  , "property": "minecraft:component"
  , "component": "minecraft:lore"
  , "cases"
  : [ { "regex": ".*Taken from the canopy of a young sycamore tree .*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/ikurlomi"
        }
      }
    ]
  , "fallback"
  : { "type": "inexactcit:match"
    , "property": "minecraft:component"
    , "component": "minecraft:custom_name"
    , "cases"
    : [ { "regex": ".*Maeluker.*metta.*"
        , "model"
        : { "type": "minecraft:model"
          , "model": "pixelatedvolume-lotc-custom-items:item/maelukermetta"
          }
        }
      ]
    , "fallback"
    : { "type": "minecraft:model", "model": "minecraft:item/stone_hoe" }
    }
  }
, "oversized_in_gui": true
}
