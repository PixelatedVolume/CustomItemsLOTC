{ "model"
: { "type": "inexactcit:match"
  , "property": "minecraft:component"
  , "component": "minecraft:custom_name"
  , "cases"
  : [ { "regex": ".*Aurum Encrusted Handle.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/aurum_handle"
        }
      }
    ]
  , "fallback"
  : { "type": "minecraft:model", "model": "minecraft:item/blaze_rod" }
  }
, "oversized_in_gui": true
}