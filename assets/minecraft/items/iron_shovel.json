{ "model"
: { "type": "inexactcit:match"
  , "property": "minecraft:component"
  , "component": "minecraft:custom_name"
  , "cases"
  : [ { "regex": ".*Woodland.*s Ballad.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/woodlands_ballad"
        }
      }
    , { "regex": ".*Ohowaki.*s Beacon.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/ohowakis_beacon"
        }
      }
    , { "regex": ".*Luara.*s Scorpion.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/luaras_scorpion"
        }
      }
    , { "regex": ".*Yatl-katzek Sitya.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/frost_salt_spear"
        }
      }
    , { "regex": ".*Celestial Acoustic Guitar.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/celestial_guitar"
        }
      }
    , { "regex": ".*Dwarven Bone Whaling Spear.*"
      , "model"
      : { "type": "minecraft:model"
        , "model": "pixelatedvolume-lotc-custom-items:item/bone_whaling_spear"
        }
      }
    ]
  , "fallback"
  : { "type": "minecraft:model", "model": "minecraft:item/iron_shovel" }
  }
, "oversized_in_gui": true
}